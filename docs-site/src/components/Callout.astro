---
interface Props {
  type?: "info" | "warning" | "success" | "danger";
  title?: string;
}

const { type = "info", title } = Astro.props;

const tone = {
  info: {
    aside: "border-primary/40 bg-primary/5",
    title: "text-primary",
    icon: "i",
  },
  warning: {
    aside: "border-amber-500/50 bg-amber-500/10",
    title: "text-amber-600 dark:text-amber-400",
    icon: "!",
  },
  success: {
    aside: "border-emerald-500/50 bg-emerald-500/10",
    title: "text-emerald-600 dark:text-emerald-400",
    icon: "+",
  },
  danger: {
    aside: "border-red-500/50 bg-red-500/10",
    title: "text-red-600 dark:text-red-400",
    icon: "x",
  },
}[type];
---

<aside
  class:list={[
    "my-6 flex gap-3 rounded-lg border-l-4 px-4 py-3",
    tone.aside,
  ]}
  role="note"
>
  <span
    aria-hidden="true"
    class:list={[
      "mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full font-mono text-xs font-bold",
      tone.title,
    ]}
  >
    {tone.icon}
  </span>
  <div class="flex-1">
    {
      title && (
        <div class:list={["mb-1 text-sm font-semibold", tone.title]}>
          {title}
        </div>
      )
    }
    <div class="text-sm leading-relaxed text-foreground/90">
      <slot />
    </div>
  </div>
</aside>
