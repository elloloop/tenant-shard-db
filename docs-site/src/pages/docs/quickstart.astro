<DocsLayout title="Quick Start">
  <h1>Quick Start</h1>
  <p>Build a task management system in 5 minutes.</p>

  <h2>1. Define Your Schema</h2>
  <p>Create <code>schema.py</code> in your project:</p>
  <pre is:raw><code>from entdb_sdk import NodeTypeDef, EdgeTypeDef, AclDefaults, field

# Node types
User = NodeTypeDef(type_id=1, name="User", fields=(
    field(1, "email", "str", required=True),
    field(2, "name", "str", required=True),
))

Task = NodeTypeDef(type_id=2, name="Task", fields=(
    field(1, "title", "str", required=True),
    field(2, "status", "enum", enum_values=("todo", "in_progress", "done")),
    field(3, "priority", "int", default=0),
), acl_defaults=AclDefaults(tenant_visible=True))

Comment = NodeTypeDef(type_id=3, name="Comment", fields=(
    field(1, "body", "str", required=True),
), acl_defaults=AclDefaults(inherit=True))

# Edge types
AssignedTo = EdgeTypeDef(edge_id=1, name="AssignedTo",
    from_type=Task, to_type=User)

HasComment = EdgeTypeDef(edge_id=2, name="HasComment",
    from_type=Task, to_type=Comment,
    propagate_share=True)  # comments inherit task ACL</code></pre>

  <h2>2. Initialize Schema Baseline</h2>
  <pre is:raw><code># Generate snapshot for CI compatibility checks
entdb init
# Creates .entdb/snapshot.json — commit this to git</code></pre>

  <h2>3. Connect and Create Data</h2>
  <pre is:raw><code>import asyncio
from entdb_sdk import DbClient
from schema import Task, Comment, HasComment, AssignedTo, User

async def main():
    async with DbClient("localhost:50051") as db:
        # Create a task with a comment, atomically
        plan = db.atomic("acme", "user:alice")
        plan.create(Task, {"title": "Ship v2", "status": "todo"}, as_="task")
        plan.create(Comment, {"body": "Let's ship it!"}, as_="comment")
        plan.edge_create(HasComment, from_="$task.id", to="$comment.id")
        result = await plan.commit(wait_applied=True)

        task_id = result.created_node_ids[0]
        print(f"Created task: {task_id}")

        # Query tasks
        tasks = await db.query(Task, "acme", "user:alice",
                               filter={"status": "todo"}, limit=10)
        for t in tasks:
            print(f"  {t.node_id}: {t.payload['title']}")

asyncio.run(main())</code></pre>

  <h2>4. Share a Task</h2>
  <pre is:raw><code>async def share_task(db, task_id):
    # Share with bob — comments are automatically shared
    await db.share(task_id, actor_id="user:bob",
                   permission="write", tenant_id="acme",
                   granted_by="user:alice")

    # Bob can see the task and all its comments
    comments = await db.connected(task_id, HasComment,
                                   tenant_id="acme", actor="user:bob")
    print(f"Bob sees {len(comments)} comments")</code></pre>

  <h2>5. Update Data</h2>
  <pre is:raw><code>async def update_task(db, task_id):
    plan = db.atomic("acme", "user:alice")
    plan.update(Task, task_id, {"status": "in_progress"})
    await plan.commit()</code></pre>

  <h2>6. Add Schema Field (Later)</h2>
  <pre is:raw><code># Add a due_date field to Task (non-breaking change)
Task = NodeTypeDef(type_id=2, name="Task", fields=(
    field(1, "title", "str", required=True),
    field(2, "status", "enum", enum_values=("todo", "in_progress", "done")),
    field(3, "priority", "int", default=0),
    field(4, "due_date", "timestamp"),  # NEW
))

# Validate in CI
$ entdb check
Schema compatible: 1 non-breaking change (field added)

# Update baseline
$ entdb snapshot --update</code></pre>

