  <h2>Full example</h2>
  <p>
    End-to-end: register the schema, connect, create, look up, query,
    update, share, delete. This mirrors the SDK's shape test.
  </p>

  <Code code={`import asyncio
from entdb_sdk import (
    DbClient,
    register_proto_schema,
    Actor,
    Permission,
    UniqueConstraintError,
    RateLimitError,
)
import schema_pb2
from schema_entdb import ProductKeys

async def main():
    async with DbClient(
        "api.example.com:443",
        api_key="sk-prod-...",
        secure=True,
    ) as db:
        register_proto_schema(schema_pb2)
        alice = db.tenant("acme").actor(Actor.user("alice"))

        # ── Seed a category and two products in one atomic plan ──
        plan = alice.plan(idempotency_key="seed-hand-tools-v1")
        plan.create(
            schema_pb2.Category(slug="hand-tools", name="Hand tools"),
            as_="hand-tools",
        )
        plan.create(
            schema_pb2.Product(
                sku="HAMMER-01", barcode="0000000000017",
                name="Claw hammer", price_cents=2499, stock=100,
            ),
            as_="hammer",
        )
        plan.create(
            schema_pb2.Product(
                sku="WRENCH-01", barcode="0000000000024",
                name="Adjustable wrench", price_cents=1799, stock=50,
            ),
            as_="wrench",
        )
        plan.edge_create(schema_pb2.BelongsTo, "$hammer", "$hand-tools")
        plan.edge_create(schema_pb2.BelongsTo, "$wrench", "$hand-tools")

        try:
            result = await plan.commit()
        except UniqueConstraintError as e:
            print(f"duplicate SKU: {e.value!r}")
            return

        print(f"seeded {len(result.created_node_ids)} nodes")

        # ── Look up by SKU (typed token) ─────────────────────────
        hammer = await alice.get_by_key(ProductKeys.sku, "HAMMER-01")
        print("found hammer", hammer.node_id)

        # ── Query by filter ──────────────────────────────────────
        affordable = await alice.query(
            schema_pb2.Product,
            filter={
                "price_cents": {"$lte": 2000},
                "stock":       {"$gt": 0},
            },
        )
        print(f"affordable, in-stock: {len(affordable)}")

        # ── Update — only price_cents gets patched ──────────────
        upd = alice.plan()
        upd.update(hammer.node_id, schema_pb2.Product(price_cents=2299))
        await upd.commit()

        # ── Share with Bob ───────────────────────────────────────
        await alice.share(hammer.node_id, Actor.user("bob"), Permission.WRITE)

        # ── Delete by class witness ─────────────────────────────
        cleanup = alice.plan()
        cleanup.delete(schema_pb2.Product, "discontinued-id")
        await cleanup.commit()

asyncio.run(main())`} lang="python" />

