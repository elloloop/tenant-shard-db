---
import "../styles/global.css";
import DocsShell from "../components/DocsShell.tsx";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

// Inline theme script to prevent flash of wrong theme
const themeScript = `
(function(){
  try {
    var m = localStorage.getItem('rfr-theme');
    var s = window.matchMedia('(prefers-color-scheme: dark)').matches;
    var t = m === 'dark' || (m !== 'light' && s) ? 'dark' : 'light';
    var d = document.documentElement;
    d.classList.remove('light','dark');
    d.classList.add(t);
    d.style.colorScheme = t;
  } catch(e){}
})()
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — EntDB Documentation</title>
    <meta name="description" content="EntDB — Multi-tenant graph database with event sourcing, ACL inheritance, and built-in GDPR compliance." />
    <script is:inline set:html={themeScript} />
  </head>
  <body class="bg-background text-foreground antialiased">
    <DocsShell client:load currentPath={currentPath}>
      <slot />
    </DocsShell>
  </body>
</html>
